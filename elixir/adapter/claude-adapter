#!/usr/bin/env python3
"""
Claude Code Adapter for Symphony

Bridges Symphony's JSON-RPC 2.0 protocol with Claude Code CLI.
Symphony launches this script as the agent command (replaces Codex app-server).

Protocol:
  Symphony → adapter: JSON-RPC requests over stdin (initialize, thread/start, turn/start)
  adapter → Symphony: JSON-RPC responses + events over stdout

The adapter:
  1. Responds to initialize/thread/start handshake
  2. On turn/start: spawns `claude` CLI with the prompt
  3. Streams turn progress events back to Symphony
  4. Sends turn/completed when claude finishes
"""

import json
import os
import subprocess
import sys
import threading
import time
import uuid


def send(msg):
    """Send a JSON-RPC message to Symphony via stdout."""
    line = json.dumps(msg) + "\n"
    sys.stdout.write(line)
    sys.stdout.flush()


def recv():
    """Receive a JSON-RPC message from Symphony via stdin."""
    line = sys.stdin.readline()
    if not line:
        return None
    return json.loads(line.strip())


def handle_initialize(msg):
    """Respond to initialize handshake."""
    send({
        "id": msg["id"],
        "result": {
            "serverInfo": {
                "name": "claude-code-adapter",
                "version": "1.0.0"
            },
            "capabilities": {}
        }
    })
    # Wait for initialized notification
    recv()


def handle_thread_start(msg):
    """Respond to thread/start — create a virtual thread."""
    thread_id = str(uuid.uuid4())
    send({
        "id": msg["id"],
        "result": {
            "thread": {
                "id": thread_id
            }
        }
    })
    return thread_id


def handle_turn_start(msg, workspace):
    """Handle turn/start — spawn Claude Code CLI and stream results."""
    turn_id = str(uuid.uuid4())
    params = msg.get("params", {})

    # Extract prompt from input
    prompt = ""
    for item in params.get("input", []):
        if item.get("type") == "text":
            prompt += item.get("text", "")

    # Send turn/started
    send({
        "id": msg["id"],
        "result": {
            "turn": {
                "id": turn_id
            }
        }
    })

    # Spawn Claude Code CLI
    env = os.environ.copy()

    claude_cmd = [
        "claude",
        "-p", prompt,
        "--dangerously-skip-permissions",
        "--output-format", "text",
    ]

    try:
        proc = subprocess.Popen(
            claude_cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            cwd=workspace,
            env=env,
        )

        # Read output
        stdout, stderr = proc.communicate()
        output = stdout.decode("utf-8", errors="replace")
        error_output = stderr.decode("utf-8", errors="replace")

        if proc.returncode == 0:
            # Send turn/completed
            send({
                "method": "turn/completed",
                "params": {
                    "turnId": turn_id,
                    "result": output[-2000:] if len(output) > 2000 else output,
                }
            })
        else:
            # Send turn/failed
            send({
                "method": "turn/failed",
                "params": {
                    "turnId": turn_id,
                    "error": error_output[-1000:] if len(error_output) > 1000 else error_output,
                }
            })

    except Exception as e:
        send({
            "method": "turn/failed",
            "params": {
                "turnId": turn_id,
                "error": str(e),
            }
        })

    return turn_id


def handle_approval_request(msg):
    """Auto-approve all approval requests."""
    send({
        "id": msg["id"],
        "result": {
            "decision": "acceptForSession"
        }
    })


def main():
    workspace = os.getcwd()

    while True:
        msg = recv()
        if msg is None:
            break

        method = msg.get("method", "")

        if method == "initialize":
            handle_initialize(msg)
        elif method == "thread/start":
            thread_id = handle_thread_start(msg)
        elif method == "turn/start":
            handle_turn_start(msg, workspace)
        elif method == "thread/stop":
            send({"id": msg.get("id"), "result": {}})
            break
        elif "Approval" in method or "approval" in method:
            handle_approval_request(msg)
        elif msg.get("id"):
            # Unknown request — send empty result
            send({"id": msg["id"], "result": {}})


if __name__ == "__main__":
    main()
